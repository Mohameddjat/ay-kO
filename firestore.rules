rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidRoom(data) {
      return data.status in ['waiting', 'racing', 'finished']
        && (data.get('winnerId', '') == null || data.get('winnerId', '') is string)
        && (data.get('winReason', '') == null || data.get('winReason', '') is string);
    }

    function isValidPlayer(data) {
      return data.id is string
        && data.progress is number
        && data.x is number
        && data.y is number
        && data.temp is number
        && data.brakeTemp is number
        && data.isExploded is bool
        && (data.get('isReady', false) is bool);
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(request.resource.data);
      allow update: if isSignedIn() && isValidRoom(request.resource.data);

      match /players/{playerId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
  }
}
