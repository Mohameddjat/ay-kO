rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidRoom(data) {
      return data.status in ['waiting', 'racing', 'finished']
        && (data.get('winnerId', '') is string)
        && (data.get('winReason', '') is string);
    }

    function isValidPlayer(data) {
      return data.id is string
        && data.progress is number
        && data.x is number
        && data.y is number
        && data.temp is number
        && data.brakeTemp is number
        && data.isExploded is bool
        && (data.get('isReady', false) is bool);
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(request.resource.data);
      allow update: if isSignedIn() && isValidRoom(request.resource.data)
        && (
          // Allow status transitions
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'winnerId', 'winReason'])
          || 
          // Allow updates if you are part of the room (for simplicity in this prototype)
          exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid))
        );

      match /players/{playerId} {
        allow read: if true;
        allow create: if isOwner(playerId) && isValidPlayer(request.resource.data);
        allow update: if isOwner(playerId) && isValidPlayer(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['x', 'y', 'angle', 'progress', 'temp', 'brakeTemp', 'gearRatio', 'isExploded', 'lastUpdate']);
        allow delete: if isOwner(playerId);
      }
    }

    // Public wallet ledger: anyone can read (so winners can compute bounty),
    // only the owner may write their own wallet.
    match /wallets/{userId} {
      allow read: if true;
      allow write: if isOwner(userId)
        && request.resource.data.credits is number
        && request.resource.data.totalWins is number
        && request.resource.data.totalCoinsEarned is number;
    }
  }
}
